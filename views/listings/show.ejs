<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3><%= listing.title %></h3>
  </div>

  <div class="card col-6 offset-3 show-card listing-card">
    <img
      src="<%= listing.image.url %>"
      class="card-img-top show-img"
      alt="listing_image"
    />

    <div class="card-body">
      <% if (listing.owner) { %>
        <p class="card-text text">
          <i>Owned By : <%= listing.owner.username %></i>
        </p>
      <% } else { %>
        <p class="card-text text">
          <i>Owned By : Unknown</i>
        </p>
      <% } %>

      <p class="card-text">
        ₹ <%= listing.price.toLocaleString("en-IN") %>
      </p>

      <p class="card-text">
        <%= listing.location %>
      </p>

      <p class="card-text">
        <%= listing.country %>
      </p>
    </div>
  </div>
</div>

<br />

<% if (currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
  <div class="btns">
    <a
      href="/listings/<%= listing._id %>/edit"
      class="btn btn-dark col-1 offset-3 edit-btn"
    >
      Edit
    </a>

    <form
      method="POST"
      action="/listings/<%= listing._id %>?_method=DELETE"
      class="d-inline"
    >
      <button class="btn btn-dark offset-3">Delete</button>
    </form>
  </div>
<% } %>

<div class="col-8 offset-3 mb-3">
  <% if (currUser) { %>
    <hr />
    <h4>Leave a review</h4>

    <form
      action="/listings/<%= listing._id %>/reviews"
      method="POST"
      novalidate
      class="needs-validation"
    >
      <div class="mb-3 mt-3">
        <label class="form-label">Rating</label>
        <input type="hidden" name="review[rating]" id="review-rating" required />
        <fieldset class="review-stars" data-rating-input="#review-rating">
          <button type="button" class="review-star-btn" data-value="1" aria-label="1 star" title="1 star">&#9733;</button>
          <button type="button" class="review-star-btn" data-value="2" aria-label="2 stars" title="2 stars">&#9733;</button>
          <button type="button" class="review-star-btn" data-value="3" aria-label="3 stars" title="3 stars">&#9733;</button>
          <button type="button" class="review-star-btn" data-value="4" aria-label="4 stars" title="4 stars">&#9733;</button>
          <button type="button" class="review-star-btn" data-value="5" aria-label="5 stars" title="5 stars">&#9733;</button>
        </fieldset>
        <div class="form-text">Choose a rating before submitting your review.</div>
        <div class="invalid-feedback">Please choose a rating.</div>
      </div>

      <div class="mb-3 mt-3">
        <label class="form-label">Comments</label>
        <textarea
          name="review[comment]"
          cols="30"
          rows="5"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Comment cannot be empty.</div>
      </div>

      <button class="btn btn-outline-dark">Submit</button>
    </form>
    <hr />
  <% } %>

  <div class="row">
    <p><b>All Reviews</b></p>

    <% if (listing.reviews && listing.reviews.length > 0) { %>
      <% for (let review of listing.reviews) { %>
        <div class="card col-5 ms-3 mb-3">
          <div class="card-body">
            <h5 class="card-title">
              @<%= review.author ? review.author.username : "deleted-user" %>
            </h5>

            <p
              class="starability-result card-text"
              data-rating="<%= review.rating %>"
            ></p>

            <% if (review.comment) { %>
              <p class="card-text"><%= review.comment %></p>
            <% } %>
          </div>

          <% if (currUser && review.author && currUser._id.equals(review.author._id)) { %>
            <form
              method="POST"
              action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
            >
              <button class="btn btn-sm btn-dark">Delete</button>
            </form>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <p>No reviews yet.</p>
    <% } %>
  </div>
</div>

<div class="col-6 offset-3 mb-3">
  <h3>Where you'll be</h3>
  <div
    id="map"
    data-map-token="<%= mapToken || '' %>"
    data-title="<%= listing.title %>"
    data-coordinates="<%= listing.geometry && Array.isArray(listing.geometry.coordinates) ? listing.geometry.coordinates.join(',') : '' %>"
  ></div>
</div>

<script src="/js/map.js"></script>
